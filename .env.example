# Jaeger MCP — Environment Variables
# Copy to .env and fill in your values.

# Required: Jaeger query service URL (no trailing slash)
JAEGER_URL=https://jaeger.example.com

# Optional: Bearer token auth (takes precedence over Basic auth)
# JAEGER_TOKEN=your-bearer-token

# Optional: HTTP Basic auth (only used if JAEGER_TOKEN is not set)
# JAEGER_USERNAME=admin
# JAEGER_PASSWORD=secret

# Optional: SSL verification (default true; set false for self-signed certs)
# JAEGER_SSL_VERIFY=false

# Optional: HTTP request timeout in seconds (default 30)
# JAEGER_TIMEOUT=30

# Optional: Retry attempts for transient failures (default 3; set 0 to disable)
# JAEGER_RETRY_ATTEMPTS=3

# Optional: TTL in seconds for discovery endpoint cache (default 120; set 0 to disable)
# JAEGER_CACHE_TTL=120
